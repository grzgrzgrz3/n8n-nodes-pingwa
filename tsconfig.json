{
  "compilerOptions": {
    "strict": true,
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "es2019",
    "lib": ["es2019", "es2020", "es2022.error"],
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "declaration": true,
    "sourceMap": true,
    "skipLibCheck": true,
    "outDir": "./dist/",
    "useUnknownInCatchVariables": false
  },
  "include": ["credentials/**/*", "nodes/**/*", "index.ts"],
  "exclude": ["**/*.test.ts", "node_modules", "dist"]
}
